# API Configuration
# Base URL for the backend API (iOS, Web)
EXPO_PUBLIC_BASE_URL=http://localhost:3333

# Android uses 10.0.2.2 to access host machine's localhost when running in emulator
# For physical Android devices, use your machine's IP address (e.g., http://192.168.1.100:3333)
EXPO_PUBLIC_ANDROID_API_URL=http://10.0.2.2:3333

# Better Auth Configuration
# The base URL where Better Auth is hosted (same as backend)
EXPO_PUBLIC_BETTER_AUTH_URL=http://localhost:3333
